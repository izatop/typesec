{
  "name": "typesec",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.14",
      "@typesec/bootstrap": "workspace:*",
      "@typesec/core": "workspace:*",
      "@typesec/the": "workspace:*",
      "@typesec/tracer": "workspace:*",
      "@typesec/unit": "workspace:*",
      "radash": "12.1.1",
      "chalk": "5.6.2",
      "zod": "4.3.6",
      "@commander-js/extra-typings": "14.0.0",
      "commander": "14.0.3"
    },
    "catalogs": {
      "build": {
        "oxlint": "^1.67.0",
        "oxfmt": "^0.52.0",
        "typescript": "6.0.3"
      }
    }
  },
  "scripts": {
    "check": "bun tsc -b packages",
    "check:watch": "bun tsc -b packages -w",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "oxlint --quiet",
    "sync": "bun typesec-sync",
    "up": "bun update -ri --latest",
    "fmt:check": "oxfmt . --check",
    "fmt:write": "oxfmt . --write"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "@typesec/bootstrap": "catalog:",
    "oxfmt": "catalog:build",
    "oxlint": "catalog:build",
    "typescript": "catalog:build"
  }
}
